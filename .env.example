# ============================================================
#  ENVIRONMENT VARIABLES  (secrets / keys)
# ------------------------------------------------------------
#  HOW TO USE:
#    1. Make a COPY of this file named exactly ".env"
#    2. Paste your real keys after the "=" signs
#    3. Never share or commit the ".env" file — it is gitignored
#
#  This ".env.example" file is safe to commit: it holds no real
#  values, just the list of names and where to get each one.
# ============================================================

# ── YouTube Data API  (v1 source — you already have this) ──
#  Manage at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ── Anthropic API  (powers the sentiment scoring) ──────────
#  Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── GDELT news  (v1 source) ────────────────────────────────
#  No key required. Listed here only so the full picture is clear.
# GDELT=not-required

# ── Bluesky  (v1 source — free, read-only) ─────────────────
#  Create an app password at https://bsky.app/settings/app-passwords
#  (Use an APP password, not your main account password.)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── Tumblr  (v1 source — free, read-only) ──────────────────
#  Register an app at https://www.tumblr.com/oauth/apps and copy the
#  "OAuth Consumer Key" (that's the API key — no user login needed).
TUMBLR_API_KEY=

# ── Reddit  (STUBBED — only needed once your access is approved) ──
#  Read-only "script" app. No username or password is used.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=loveisland-sentiment:v1 (by /u/your_reddit_username)

# ── X / Twitter  (STUBBED — paid API, for later) ───────────
# X_BEARER_TOKEN=

# ── Optional: random text used to anonymize comment authors ──
#  Any random string. If left blank a default is used.
# AUTHOR_HASH_SALT=
